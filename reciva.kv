# ============================================================
#  ESTADÍSTICAS
# ============================================================
<EstadisticasScreen>:
    canvas.before:
        Color:
            rgba: 0.945, 0.918, 0.882, 1
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: 'horizontal'

        MenuLateral:
            pantalla_actual: 'estadisticas'
            rol: app.user_rol

        BoxLayout:
            orientation: 'vertical'
            padding: [20, 16]
            spacing: 10

            # ── Título + filtros ──────────────────────────────
            BoxLayout:
                size_hint_y: None
                height: 44
                spacing: 10
                Label:
                    text: 'Estadísticas de Pagos'
                    font_name: 'Sora'
                    font_size: 20
                    bold: True
                    color: 0.106, 0.082, 0.071, 1
                    size_hint_x: 0.30
                    halign: 'left'
                    text_size: self.size
                FilterPill:
                    size_hint_x: 0.10
                    Spinner:
                        id: sp_año
                        text: 'Año'
                        values: root.anios
                        font_size: 13
                        background_normal: ''
                        background_color: 0, 0, 0, 0
                        color: 0.106, 0.082, 0.071, 1
                FilterPill:
                    size_hint_x: 0.14
                    Spinner:
                        id: sp_mes
                        text: 'Mes'
                        values: root.meses
                        font_size: 13
                        background_normal: ''
                        background_color: 0, 0, 0, 0
                        color: 0.106, 0.082, 0.071, 1
                PillButton:
                    text: 'Actualizar'
                    size_hint_x: 0.12
                    font_size: 13
                    bg_color: 0.106, 0.082, 0.071, 1
                    pressed_color: 0.082, 0.063, 0.055, 1
                    pill_radius: 8
                    on_press: root.actualizar()
                Label:
                    text: root.periodo_label
                    font_size: 13
                    color: 0.549, 0.502, 0.467, 1
                    halign: 'right'
                    valign: 'middle'
                    text_size: self.size

            # ── Cards de resumen ──────────────────────────────
            BoxLayout:
                size_hint_y: None
                height: 82
                spacing: 12

                AccentCard:
                    accent_color: 0.106, 0.082, 0.071, 1
                    padding: [14, 8]
                    Label:
                        id: lbl_facturado
                        text: '—'
                        bold: True
                        font_size: 20
                        color: 0.106, 0.082, 0.071, 1
                        halign: 'left'
                        text_size: self.size
                    Label:
                        text: 'Total facturado'
                        font_size: 11
                        color: 0.549, 0.502, 0.467, 1
                        halign: 'left'
                        text_size: self.size

                AccentCard:
                    accent_color: 0.122, 0.533, 0.220, 1
                    padding: [14, 8]
                    Label:
                        id: lbl_recaudado
                        text: '—'
                        bold: True
                        font_size: 20
                        color: 0.122, 0.533, 0.220, 1
                        halign: 'left'
                        text_size: self.size
                    Label:
                        text: 'Total recaudado'
                        font_size: 11
                        color: 0.549, 0.502, 0.467, 1
                        halign: 'left'
                        text_size: self.size

                AccentCard:
                    accent_color: 0.200, 0.470, 0.820, 1
                    padding: [14, 8]
                    Label:
                        id: lbl_pct
                        text: '—'
                        bold: True
                        font_size: 20
                        color: 0.549, 0.502, 0.467, 1
                        halign: 'left'
                        text_size: self.size
                    Label:
                        text: '% de cobro'
                        font_size: 11
                        color: 0.549, 0.502, 0.467, 1
                        halign: 'left'
                        text_size: self.size

                AccentCard:
                    accent_color: 0.914, 0.306, 0.173, 1
                    padding: [14, 8]
                    Label:
                        id: lbl_cartera
                        text: '—'
                        bold: True
                        font_size: 20
                        color: 0.914, 0.306, 0.173, 1
                        halign: 'left'
                        text_size: self.size
                    Label:
                        text: 'Cartera pendiente'
                        font_size: 11
                        color: 0.549, 0.502, 0.467, 1
                        halign: 'left'
                        text_size: self.size

            # ── Aviso recaudos sin factura ────────────────────
            Label:
                id: lbl_aviso_huerfanos
                text: ''
                size_hint_y: None
                height: 20 if self.text else 0
                font_size: 11
                color: 0.914, 0.306, 0.173, 1
                halign: 'left'
                text_size: self.size

            # ── Botones de vista ──────────────────────────────
            BoxLayout:
                size_hint_y: None
                height: 34
                spacing: 8
                TabButton:
                    id: btn_est
                    text: 'Por Estrato'
                    size_hint_x: None
                    width: 120
                    font_size: 12
                    is_active: True
                    on_press: root.cambiar_vista('estrato')
                TabButton:
                    id: btn_bar
                    text: 'Por Barrio'
                    size_hint_x: None
                    width: 120
                    font_size: 12
                    on_press: root.cambiar_vista('barrio')
                Widget:
                    size_hint_x: 1
                TabButton:
                    id: btn_huerfanos
                    text: 'Pagos sin factura'
                    size_hint_x: None
                    width: 150
                    font_size: 12
                    on_press: root.toggle_huerfanos()

            # ── Encabezado de tabla ───────────────────────────
            BoxLayout:
                size_hint_y: None
                height: 28
                canvas.before:
                    Color:
                        rgba: 0.106, 0.082, 0.071, 1
                    Rectangle:
                        pos: self.pos
                        size: self.size
                Label:
                    id: lbl_hdr_grupo
                    text: 'Estrato'
                    size_hint_x: 0.20
                    bold: True
                    font_size: 11
                    color: 0.906, 0.863, 0.812, 1
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.width - 4, self.height
                Label:
                    text: 'Suscriptores'
                    size_hint_x: 0.10
                    bold: True
                    font_size: 11
                    color: 0.906, 0.863, 0.812, 1
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.width, self.height
                Label:
                    text: 'Facturado'
                    size_hint_x: 0.22
                    bold: True
                    font_size: 11
                    color: 0.906, 0.863, 0.812, 1
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.width, self.height
                Label:
                    text: 'Recaudado'
                    size_hint_x: 0.22
                    bold: True
                    font_size: 11
                    color: 0.906, 0.863, 0.812, 1
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.width, self.height
                Label:
                    text: '% Cobro'
                    size_hint_x: 0.10
                    bold: True
                    font_size: 11
                    color: 0.906, 0.863, 0.812, 1
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.width, self.height
                Label:
                    text: 'Cartera'
                    size_hint_x: 0.16
                    bold: True
                    font_size: 11
                    color: 0.906, 0.863, 0.812, 1
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.width, self.height

            # ── Tabla scrolleable ─────────────────────────────
            ScrollView:
                BoxLayout:
                    id: tabla_body
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: 1





# ============================================================
#  VOLCADO
# ============================================================
<VolcadoScreen>:
    canvas.before:
        Color:
            rgba: 0.945, 0.918, 0.882, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'horizontal'

        MenuLateral:
            pantalla_actual: 'volcado'
            rol: app.user_rol

        # ── Contenido ────────────────────────────────────────
        BoxLayout:
            orientation: 'vertical'
            spacing: 0

            # ── Panel superior fijo ──────────────────────────
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: 110
                padding: [24, 10, 24, 6]
                spacing: 4
                canvas.before:
                    Color:
                        rgba: 1, 1, 1, 1
                    Rectangle:
                        pos: self.pos
                        size: self.size
                canvas.after:
                    Color:
                        rgba: 0.788, 0.016, 0.043, 0.18
                    Rectangle:
                        pos: self.x, self.y
                        size: self.width, 2

                BoxLayout:
                    size_hint_y: None
                    height: 28
                    spacing: 8
                    Label:
                        text: 'Salida:'
                        font_name: 'Jakarta'
                        font_size: 11
                        color: 0.549, 0.502, 0.467, 1
                        size_hint_x: None
                        width: 48
                        halign: 'right'
                        valign: 'middle'
                        text_size: self.size
                    Label:
                        id: lbl_salida
                        text: '—'
                        font_name: 'Jakarta'
                        font_size: 11
                        color: 0.106, 0.082, 0.071, 1
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size
                    PillButton:
                        text: 'Cambiar'
                        font_size: 11
                        size_hint: None, None
                        size: 80, 26
                        bg_color: 0.106, 0.082, 0.071, 1
                        pressed_color: 0.753, 0.227, 0.129, 1
                        pill_radius: 6
                        on_press: root.cambiar_carpeta_salida()

                BoxLayout:
                    size_hint_y: None
                    height: 28
                    spacing: 8
                    Label:
                        text: 'Período:'
                        font_name: 'Jakarta'
                        font_size: 11
                        color: 0.549, 0.502, 0.467, 1
                        size_hint_x: None
                        width: 56
                        halign: 'right'
                        valign: 'middle'
                        text_size: self.size
                    TextInput:
                        id: inp_periodo
                        hint_text: 'AAAAMM'
                        text: ''
                        font_name: 'Jakarta'
                        font_size: 13
                        size_hint_x: None
                        width: 100
                        size_hint_y: None
                        height: 28
                        multiline: False
                        foreground_color: 0.106, 0.082, 0.071, 1
                        background_color: 0.984, 0.969, 0.945, 1
                        background_normal: ''
                        background_active: ''
                        padding: [8, 4]
                    Label:
                        text: ''
                        size_hint_x: 1

                BoxLayout:
                    size_hint_y: None
                    height: 26
                    Label:
                        id: lbl_estado
                        text: ''
                        font_name: 'Jakarta'
                        font_size: 11
                        color: 0.549, 0.502, 0.467, 1
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size

            # ── Barra de tabs ────────────────────────────────
            BoxLayout:
                size_hint_y: None
                height: 40
                spacing: 2
                padding: [16, 4, 16, 0]
                canvas.before:
                    Color:
                        rgba: 0.984, 0.969, 0.945, 1
                    Rectangle:
                        pos: self.pos
                        size: self.size
                TabButton:
                    id: tab_tarifas
                    text: 'Tarifas'
                    is_active: True
                    on_press: root.cambiar_tab('tarifas')
                TabButton:
                    id: tab_exportar
                    text: 'Exportar'
                    on_press: root.cambiar_tab('exportar')
                Widget
                PillButton:
                    text: '✉  Correo'
                    size_hint: None, None
                    size: 110, 30
                    bg_color: 0.106, 0.082, 0.071, 1
                    pressed_color: 0.082, 0.063, 0.055, 1
                    pill_radius: 8
                    font_size: 11
                    on_press: root.popup_config_email()

            # ── Panel Tarifas ────────────────────────────────
            BoxLayout:
                id: panel_tarifas
                orientation: 'vertical'
                padding: [20, 12, 20, 8]
                spacing: 0

                BoxLayout:
                    size_hint_y: None
                    height: 32
                    padding: [12, 0]
                    canvas.before:
                        Color:
                            rgba: 0.106, 0.082, 0.071, 1
                        Rectangle:
                            pos: self.pos
                            size: self.size
                    Label:
                        text: 'USO / CATEGORIA'
                        font_name: 'Jakarta'
                        font_size: 11
                        bold: True
                        color: 1, 1, 1, 1
                        size_hint_x: 0.30
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size
                    Label:
                        text: 'VALOR'
                        font_name: 'Jakarta'
                        font_size: 11
                        bold: True
                        color: 1, 1, 1, 1
                        size_hint_x: 0.14
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size
                    Label:
                        text: 'SUB/CON %'
                        font_name: 'Jakarta'
                        font_size: 11
                        bold: True
                        color: 1, 1, 1, 1
                        size_hint_x: 0.14
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size
                    Label:
                        text: 'TARIFA MEDIA'
                        font_name: 'Jakarta'
                        font_size: 11
                        bold: True
                        color: 1, 1, 1, 1
                        size_hint_x: 0.22
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size
                    Label:
                        text: ''
                        size_hint_x: 0.20

                ScrollView:
                    do_scroll_x: False
                    BoxLayout:
                        id: tabla_tarifas
                        orientation: 'vertical'
                        size_hint_y: None
                        height: self.minimum_height

            # ── Panel Exportar ───────────────────────────────
            BoxLayout:
                id: panel_exportar
                orientation: 'vertical'
                opacity: 0
                disabled: True
                size_hint_y: None
                height: 0
                padding: [28, 18, 28, 18]
                spacing: 12

                # Aviso informativo
                BoxLayout:
                    size_hint_y: None
                    height: 42
                    padding: [16, 0, 16, 0]
                    canvas.before:
                        Color:
                            rgba: 0.984, 0.973, 0.961, 1
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [8]
                        Color:
                            rgba: 0.788, 0.016, 0.043, 0.35
                        Rectangle:
                            pos: self.pos
                            size: 4, self.height
                    Label:
                        text: 'Valida primero para verificar que los datos esten completos antes de exportar.'
                        font_name: 'Jakarta'
                        font_size: 11
                        color: 0.549, 0.502, 0.467, 1
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size

                # Tarjeta de resultados de validación
                BoxLayout:
                    size_hint_y: 1
                    padding: [20, 14, 20, 14]
                    canvas.before:
                        Color:
                            rgba: 1, 1, 1, 1
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [10]
                        Color:
                            rgba: 0.906, 0.863, 0.812, 0.7
                        Line:
                            rounded_rectangle: self.x, self.y, self.width, self.height, 10
                            width: 1
                    Label:
                        id: lbl_validacion
                        text: 'Presiona Validar antes de exportar'
                        font_name: 'Jakarta'
                        font_size: 13
                        color: 0.549, 0.502, 0.467, 1
                        halign: 'left'
                        valign: 'top'
                        text_size: self.size

                # Estado de exportación
                Label:
                    id: lbl_export_estado
                    text: ''
                    font_name: 'Jakarta'
                    font_size: 12
                    color: 0.549, 0.502, 0.467, 1
                    size_hint_y: None
                    height: 24
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size

                # Botones de acción
                BoxLayout:
                    size_hint_y: None
                    height: 52
                    spacing: 14
                    PillButton:
                        text: 'Validar'
                        font_size: 14
                        bg_color: 0.106, 0.082, 0.071, 1
                        pressed_color: 0.300, 0.200, 0.150, 1
                        pill_radius: 10
                        on_press: root.validar()
                    PillButton:
                        text: 'Exportar 5 archivos'
                        font_size: 14
                        bg_color: 0.788, 0.016, 0.043, 1
                        pressed_color: 0.561, 0.012, 0.031, 1
                        pill_radius: 10
                        on_press: root.exportar()

                Widget:

# ── Gestión de Roles ──────────────────────────────────────────────────────────
<RolesScreen>:
    canvas.before:
        Color:
            rgba: 0.945, 0.918, 0.882, 1
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: 'horizontal'

        MenuLateral:
            pantalla_actual: 'roles'
            rol: app.user_rol

        BoxLayout:
            orientation: 'vertical'
            padding: [28, 24]
            spacing: 16

            BoxLayout:
                size_hint_y: None
                height: 44
                spacing: 12
                Label:
                    text: 'Gestión de Roles'
                    font_name: 'Sora'
                    font_size: 20
                    bold: True
                    color: 0.106, 0.082, 0.071, 1
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size
                PillButton:
                    text: '+ Nuevo Rol'
                    size_hint: None, None
                    size: 148, 38
                    bg_color: 0.106, 0.082, 0.071, 1
                    pressed_color: 0.082, 0.063, 0.055, 1
                    pill_radius: 10
                    font_size: 13
                    on_press: root.popup_nuevo_rol()

            Label:
                text: root.mensaje
                font_name: 'Jakarta'
                font_size: 12
                color: 0.549, 0.502, 0.467, 1
                size_hint_y: None
                height: 20
                halign: 'left'
                text_size: self.size

            TableHeader:
                Label:
                    text: 'Rol'
                    size_hint_x: 0.35
                    bold: True
                    font_size: 13
                    color: 0.906, 0.863, 0.812, 1
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.width - 8, self.height
                Label:
                    text: 'Usuarios asignados'
                    size_hint_x: 0.25
                    bold: True
                    font_size: 13
                    color: 0.906, 0.863, 0.812, 1
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.width - 8, self.height
                Label:
                    text: 'Acciones'
                    size_hint_x: 0.40
                    bold: True
                    font_size: 13
                    color: 0.906, 0.863, 0.812, 1
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.width - 8, self.height

            ScrollView:
                BoxLayout:
                    id: lista_roles
                    orientation: 'vertical'
                    size_hint_y: None
                    spacing: 1
                    height: self.minimum_height
