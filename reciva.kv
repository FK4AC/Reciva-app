# ============================================================
#  Reciva — Design System «Recibo»
#  Paleta: vermellón #E94E2C · tinta #1B1512 · crema #F1EAE1
# ============================================================

<SinConexionScreen>:
    canvas.before:
        Color:
            rgba: 0.945, 0.918, 0.882, 1
        Rectangle:
            pos: self.pos
            size: self.size
    FloatLayout:
        BoxLayout:
            orientation: 'vertical'
            size_hint: 0.38, None
            height: 320
            pos_hint: {'center_x': 0.5, 'center_y': 0.52}
            spacing: 0
            padding: [40, 36, 40, 32]
            canvas.before:
                Color:
                    rgba: 1, 1, 1, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [14]

            # Icono / franja superior
            Widget:
                size_hint_y: None
                height: 6
                canvas.before:
                    Color:
                        rgba: 0.914, 0.306, 0.173, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [3]

            Widget:
                size_hint_y: None
                height: 24

            Label:
                text: 'Sin conexión'
                font_name: 'Sora'
                font_size: 22
                bold: True
                color: 0.106, 0.082, 0.071, 1
                size_hint_y: None
                height: 36
                halign: 'center'
                text_size: self.size

            Widget:
                size_hint_y: None
                height: 10

            Label:
                text: 'No se pudo conectar a la base de datos.\nVerifica tu conexión a internet e inténtalo de nuevo.'
                font_size: 13
                color: 0.549, 0.502, 0.467, 1
                size_hint_y: None
                height: 52
                halign: 'center'
                valign: 'top'
                text_size: self.size

            Widget:
                size_hint_y: 1

            PillButton:
                text: 'Reintentar'
                font_name: 'Sora'
                font_size: 14
                bold: True
                size_hint_y: None
                height: 46
                bg_color: 0.106, 0.082, 0.071, 1
                pressed_color: 0.082, 0.063, 0.055, 1
                pill_radius: 8
                on_press: root.reintentar()

# --- Estilos globales ---
<Label>:
    font_name: 'Jakarta'

<Button>:
    font_name: 'Jakarta'

<TextInput>:
    font_name: 'Jakarta'
    foreground_color: 0.106, 0.082, 0.071, 1
    background_color: 1, 1, 1, 1
    background_active: ''
    cursor_color: 0.914, 0.306, 0.173, 1
    hint_text_color: 0.549, 0.502, 0.467, 1
    padding: [12, 10]

<Spinner>:
    font_name: 'Jakarta'
    color: 0.106, 0.082, 0.071, 1
    background_color: 1, 1, 1, 1
    background_normal: ''

# ============================================================
#  MENU LATERAL
# ============================================================
<MenuLateral>:
    orientation: 'vertical'
    size_hint_x: 0.2
    spacing: 0
    padding: 0

    canvas.before:
        Color:
            rgba: 0.231, 0.173, 0.137, 1
        Rectangle:
            pos: self.pos
            size: self.size

    # Header — logo
    BoxLayout:
        size_hint_y: None
        height: 72
        padding: [14, 10]
        canvas.before:
            Color:
                rgba: 0.176, 0.125, 0.098, 1
            Rectangle:
                pos: self.pos
                size: self.size
        Image:
            source: 'logo_png/05-logo-blanco.png'
            fit_mode: 'contain'
            halign: 'left'
            allow_stretch: True
            keep_ratio: True
            mipmap: True

    Widget:
        size_hint_y: None
        height: 1
        canvas.before:
            Color:
                rgba: 0.906, 0.863, 0.812, 0.12
            Rectangle:
                pos: self.pos
                size: self.size

    # ── Usuario actual ────────────────────────────────────
    BoxLayout:
        size_hint_y: None
        height: 54
        padding: [12, 9]
        spacing: 10
        canvas.before:
            Color:
                rgba: 0.176, 0.125, 0.098, 1
            Rectangle:
                pos: self.pos
                size: self.size
        BoxLayout:
            size_hint: None, None
            size: 32, 32
            canvas.before:
                Color:
                    rgba: 0.914, 0.306, 0.173, 1
                Ellipse:
                    pos: self.pos
                    size: self.size
            Label:
                text: app.usuario_nombre[:1].upper() if app.usuario_nombre else 'U'
                font_size: 13
                bold: True
                color: 1, 1, 1, 1
        BoxLayout:
            orientation: 'vertical'
            Label:
                text: app.usuario_nombre or 'Usuario'
                font_size: 11
                bold: True
                color: 1, 1, 1, 1
                halign: 'left'
                text_size: self.size
            Label:
                text: app.user_rol
                font_size: 9
                color: 0.749, 0.663, 0.612, 1
                halign: 'left'
                text_size: self.size

    Widget:
        size_hint_y: None
        height: 1
        canvas.before:
            Color:
                rgba: 0.906, 0.863, 0.812, 0.12
            Rectangle:
                pos: self.pos
                size: self.size

    Widget:
        size_hint_y: None
        height: 6

    SidebarButton:
        text: 'Dashboard'
        size_hint_y: None
        height: 44 if app.perm_dashboard else 0
        opacity: 1 if app.perm_dashboard else 0
        disabled: not app.perm_dashboard
        is_active: root.pantalla_actual == 'dashboard'
        on_press: root.ir_a('dashboard')

    SidebarButton:
        text: 'Suscriptores'
        size_hint_y: None
        height: 44 if app.perm_suscriptores else 0
        opacity: 1 if app.perm_suscriptores else 0
        disabled: not app.perm_suscriptores
        is_active: root.pantalla_actual == 'suscriptores'
        on_press: root.ir_a('suscriptores')

    SidebarButton:
        text: 'Facturación'
        size_hint_y: None
        height: 44 if app.perm_facturacion else 0
        opacity: 1 if app.perm_facturacion else 0
        disabled: not app.perm_facturacion
        is_active: root.pantalla_actual == 'facturacion'
        on_press: root.ir_a('facturacion')

    SidebarButton:
        text: 'Tickets / PQR'
        size_hint_y: None
        height: 44 if app.perm_tickets else 0
        opacity: 1 if app.perm_tickets else 0
        disabled: not app.perm_tickets
        is_active: root.pantalla_actual == 'tickets'
        on_press: root.ir_a('tickets')

    SidebarButton:
        text: 'Importar'
        size_hint_y: None
        height: 44 if app.perm_importar else 0
        opacity: 1 if app.perm_importar else 0
        disabled: not app.perm_importar
        is_active: root.pantalla_actual == 'importar'
        on_press: root.ir_a('importar')

    SidebarButton:
        text: 'Usuarios'
        size_hint_y: None
        height: 44 if app.perm_usuarios else 0
        opacity: 1 if app.perm_usuarios else 0
        disabled: not app.perm_usuarios
        is_active: root.pantalla_actual == 'usuarios'
        on_press: root.ir_a('usuarios')

    SidebarButton:
        text: 'Estadísticas'
        size_hint_y: None
        height: 44 if app.perm_estadisticas else 0
        opacity: 1 if app.perm_estadisticas else 0
        disabled: not app.perm_estadisticas
        is_active: root.pantalla_actual == 'estadisticas'
        on_press: root.ir_a('estadisticas')

    SidebarButton:
        text: 'Volcado'
        size_hint_y: None
        height: 44 if app.perm_volcado else 0
        opacity: 1 if app.perm_volcado else 0
        disabled: not app.perm_volcado
        is_active: root.pantalla_actual == 'volcado'
        on_press: root.ir_a('volcado')

    SidebarButton:
        text: 'Gestión de Roles'
        size_hint_y: None
        height: 44 if app.perm_roles else 0
        opacity: 1 if app.perm_roles else 0
        disabled: not app.perm_roles
        is_active: root.pantalla_actual == 'roles'
        on_press: root.ir_a('roles')

    Widget

    Widget:
        size_hint_y: None
        height: 1
        canvas.before:
            Color:
                rgba: 0.906, 0.863, 0.812, 0.12
            Rectangle:
                pos: self.pos
                size: self.size

    BoxLayout:
        size_hint_y: None
        height: 54
        padding: [12, 7]
        PillButton:
            text: 'Cerrar Sesión'
            font_size: 12
            bg_color: 0.753, 0.227, 0.129, 1
            pressed_color: 0.580, 0.180, 0.098, 1
            pill_radius: 8
            on_press: root.cerrar_sesion()

# ============================================================
#  LOGIN
# ============================================================
<LoginScreen>:
    BoxLayout:
        orientation: 'horizontal'

        # ── Panel izquierdo — marca ──────────────────────────
        BoxLayout:
            orientation: 'vertical'
            size_hint_x: 0.42
            padding: [44, 48, 36, 36]
            spacing: 0
            canvas.before:
                Color:
                    rgba: 0.082, 0.063, 0.055, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Widget

            Image:
                source: 'logo_png/05-logo-blanco.png'
                fit_mode: 'contain'
                size_hint_y: None
                height: 68
                allow_stretch: True
                keep_ratio: True
                halign: 'left'
                mipmap: True

            Widget:
                size_hint_y: None
                height: 36

            Label:
                text: 'Sistema de gestión\nde aseo'
                font_name: 'Sora'
                font_size: 24
                bold: True
                color: 1, 1, 1, 1
                size_hint_y: None
                height: 80
                halign: 'left'
                text_size: self.size

            Widget:
                size_hint_y: None
                height: 14

            Label:
                text: 'Administra suscriptores,\nfacturación y recaudos desde\nun solo lugar.'
                font_size: 13
                color: 0.549, 0.502, 0.467, 1
                size_hint_y: None
                height: 64
                halign: 'left'
                text_size: self.size

            Widget

            Label:
                text: 'INGESAM · Hatonuevo, La Guajira'
                font_size: 9
                color: 0.345, 0.290, 0.255, 1
                size_hint_y: None
                height: 20
                halign: 'left'
                text_size: self.size

        # ── Panel derecho — formulario ───────────────────────
        BoxLayout:
            orientation: 'vertical'
            size_hint_x: 0.58
            canvas.before:
                Color:
                    rgba: 0.945, 0.918, 0.882, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            FloatLayout:
                # ── Card del formulario ──
                BoxLayout:
                    orientation: 'vertical'
                    size_hint: 0.72, None
                    height: 420
                    pos_hint: {'center_x': 0.5, 'center_y': 0.52}
                    spacing: 0
                    padding: [40, 36, 40, 32]
                    canvas.before:
                        Color:
                            rgba: 1, 1, 1, 1
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [14]
                        Color:
                            rgba: 0.906, 0.863, 0.812, 0.5
                        Line:
                            rounded_rectangle: self.x, self.y, self.width, self.height, 14
                            width: 1

                    Label:
                        text: 'Iniciar sesión'
                        font_name: 'Sora'
                        font_size: 19
                        bold: True
                        color: 0.106, 0.082, 0.071, 1
                        size_hint_y: None
                        height: 34
                        halign: 'left'
                        text_size: self.size

                    Label:
                        text: 'Ingresa tus credenciales para continuar'
                        font_name: 'Jakarta'
                        font_size: 11
                        color: 0.549, 0.502, 0.467, 1
                        size_hint_y: None
                        height: 20
                        halign: 'left'
                        text_size: self.size

                    Widget:
                        size_hint_y: None
                        height: 28

                    # ── Campo email ──
                    BoxLayout:
                        orientation: 'vertical'
                        size_hint_y: None
                        height: 58
                        spacing: 0
                        Label:
                            text: 'Correo electrónico'
                            font_name: 'Jakarta'
                            font_size: 10
                            color: 0.549, 0.502, 0.467, 1
                            size_hint_y: None
                            height: 16
                            halign: 'left'
                            text_size: self.size
                        TextInput:
                            id: email
                            hint_text: 'usuario@correo.com'
                            multiline: False
                            size_hint_y: None
                            height: 38
                            background_color: 0, 0, 0, 0
                            background_normal: ''
                            background_active: ''
                            foreground_color: 0.106, 0.082, 0.071, 1
                            cursor_color: 0.914, 0.306, 0.173, 1
                            hint_text_color: 0.753, 0.710, 0.675, 1
                            padding: [2, 8, 2, 6]
                            font_size: 13
                            canvas.after:
                                Color:
                                    rgba: (0.914, 0.306, 0.173, 1) if self.focus else (0.906, 0.863, 0.812, 1)
                                Line:
                                    points: self.x, self.y + 2, self.x + self.width, self.y + 2
                                    width: 1.4

                    Widget:
                        size_hint_y: None
                        height: 14

                    # ── Campo contraseña ──
                    BoxLayout:
                        orientation: 'vertical'
                        size_hint_y: None
                        height: 58
                        spacing: 0
                        Label:
                            text: 'Contraseña'
                            font_name: 'Jakarta'
                            font_size: 10
                            color: 0.549, 0.502, 0.467, 1
                            size_hint_y: None
                            height: 16
                            halign: 'left'
                            text_size: self.size
                        TextInput:
                            id: password
                            hint_text: '••••••••'
                            password: True
                            multiline: False
                            size_hint_y: None
                            height: 38
                            background_color: 0, 0, 0, 0
                            background_normal: ''
                            background_active: ''
                            foreground_color: 0.106, 0.082, 0.071, 1
                            cursor_color: 0.914, 0.306, 0.173, 1
                            hint_text_color: 0.753, 0.710, 0.675, 1
                            padding: [2, 8, 2, 6]
                            font_size: 13
                            canvas.after:
                                Color:
                                    rgba: (0.914, 0.306, 0.173, 1) if self.focus else (0.906, 0.863, 0.812, 1)
                                Line:
                                    points: self.x, self.y + 2, self.x + self.width, self.y + 2
                                    width: 1.4
                            on_text_validate: root.do_login(email.text, self.text)

                    Widget:
                        size_hint_y: None
                        height: 8

                    Label:
                        text: root.error_msg
                        font_name: 'Jakarta'
                        font_size: 10.5
                        color: 0.914, 0.306, 0.173, 1
                        size_hint_y: None
                        height: 20
                        halign: 'center'
                        text_size: self.size

                    Widget:
                        size_hint_y: None
                        height: 12

                    PillButton:
                        text: 'Iniciar sesión'
                        font_name: 'Sora'
                        font_size: 13
                        size_hint_y: None
                        height: 48
                        pill_radius: 24
                        on_press: root.do_login(email.text, password.text)

# ============================================================
#  DASHBOARD
# ============================================================
<DashboardScreen>:
    canvas.before:
        Color:
            rgba: 0.945, 0.918, 0.882, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'horizontal'

        MenuLateral:
            pantalla_actual: 'dashboard'
            rol: app.user_rol

        BoxLayout:
            orientation: 'vertical'
            padding: [28, 24]
            spacing: 18

            Label:
                text: 'Panel Principal'
                font_name: 'Sora'
                font_size: 22
                bold: True
                color: 0.106, 0.082, 0.071, 1
                size_hint_y: None
                height: 36
                halign: 'left'
                text_size: self.size

            Label:
                text: 'Bienvenido, ' + root.usuario_nombre
                font_size: 13
                color: 0.549, 0.502, 0.467, 1
                size_hint_y: None
                height: 22
                halign: 'left'
                text_size: self.size

            # ── Selector de período ──
            BoxLayout:
                size_hint_y: None
                height: 42
                spacing: 10

                Label:
                    text: root.periodo_label
                    font_size: 12
                    bold: True
                    color: 0.106, 0.082, 0.071, 1
                    size_hint_x: None
                    width: 180
                    halign: 'left'
                    text_size: self.size

                FilterPill:
                    size_hint_x: None
                    width: 110
                    Spinner:
                        id: dash_año
                        text: 'Año'
                        values: root.años_disponibles
                        background_color: 0, 0, 0, 0
                        background_normal: ''
                        color: 0.106, 0.082, 0.071, 1
                        font_size: 12
                        on_text: root.cambiar_periodo(self.text, dash_mes.text)

                FilterPill:
                    size_hint_x: None
                    width: 100
                    Spinner:
                        id: dash_mes
                        text: 'Mes'
                        values: root.meses_disponibles
                        background_color: 0, 0, 0, 0
                        background_normal: ''
                        color: 0.106, 0.082, 0.071, 1
                        font_size: 12
                        on_text: root.cambiar_periodo(dash_año.text, self.text)

                Widget

            # Fila 1 — suscriptores, facturado, recaudado
            GridLayout:
                cols: 3
                spacing: 14
                size_hint_y: None
                height: 110

                # Suscriptores (clickeable → barrios)
                AccentCard:
                    accent_color: 0.106, 0.082, 0.071, 1
                    padding: [16, 12]
                    on_touch_up: if self.collide_point(*args[1].pos): root.popup_barrios()
                    Label:
                        text: root.total_suscriptores
                        font_size: 26
                        bold: True
                        color: 0.106, 0.082, 0.071, 1
                        halign: 'left'
                        text_size: self.size
                    Label:
                        text: 'Suscriptores  [size=11][color=8c8077]▶ por barrio[/color][/size]'
                        markup: True
                        font_size: 12
                        color: 0.549, 0.502, 0.467, 1
                        halign: 'left'
                        text_size: self.size

                AccentCard:
                    accent_color: 0.122, 0.533, 0.220, 1
                    padding: [16, 12]
                    Label:
                        text: root.total_facturado
                        font_size: 26
                        bold: True
                        color: 0.106, 0.082, 0.071, 1
                        halign: 'left'
                        text_size: self.size
                    Label:
                        text: 'Total Facturado'
                        font_size: 12
                        color: 0.549, 0.502, 0.467, 1
                        halign: 'left'
                        text_size: self.size

                AccentCard:
                    accent_color: 0.200, 0.470, 0.820, 1
                    padding: [16, 12]
                    Label:
                        text: root.total_recaudado
                        font_size: 26
                        bold: True
                        color: 0.106, 0.082, 0.071, 1
                        halign: 'left'
                        text_size: self.size
                    Label:
                        text: 'Total Recaudado'
                        font_size: 12
                        color: 0.549, 0.502, 0.467, 1
                        halign: 'left'
                        text_size: self.size

            # Fila 2 — deuda, con deuda, PQR, % cobro
            GridLayout:
                cols: 4
                spacing: 14
                size_hint_y: None
                height: 110

                AccentCard:
                    accent_color: 0.914, 0.306, 0.173, 1
                    padding: [16, 12]
                    Label:
                        text: root.deuda_total
                        font_size: 22
                        bold: True
                        color: 0.914, 0.306, 0.173, 1
                        halign: 'left'
                        text_size: self.size
                    Label:
                        text: 'Deuda Total'
                        font_size: 12
                        color: 0.549, 0.502, 0.467, 1
                        halign: 'left'
                        text_size: self.size

                AccentCard:
                    accent_color: 0.914, 0.306, 0.173, 1
                    padding: [16, 12]
                    Label:
                        text: root.sus_con_deuda
                        font_size: 22
                        bold: True
                        color: 0.914, 0.306, 0.173, 1
                        halign: 'left'
                        text_size: self.size
                    Label:
                        text: 'Con Deuda'
                        font_size: 12
                        color: 0.549, 0.502, 0.467, 1
                        halign: 'left'
                        text_size: self.size

                AccentCard:
                    accent_color: 0.435, 0.212, 0.682, 1
                    padding: [16, 12]
                    Label:
                        text: root.pqr_abiertas
                        font_size: 22
                        bold: True
                        color: 0.435, 0.212, 0.682, 1
                        halign: 'left'
                        text_size: self.size
                    Label:
                        text: 'PQR Sin Resolver'
                        font_size: 12
                        color: 0.549, 0.502, 0.467, 1
                        halign: 'left'
                        text_size: self.size

                AccentCard:
                    accent_color: 0.122, 0.533, 0.220, 1
                    padding: [16, 12, 16, 6]
                    Label:
                        text: root.tasa_cobro
                        font_size: 22
                        bold: True
                        color: root.tasa_cobro_color
                        halign: 'left'
                        text_size: self.size
                    Label:
                        text: 'Tasa de Cobro'
                        font_size: 12
                        color: 0.549, 0.502, 0.467, 1
                        halign: 'left'
                        text_size: self.size
                    Widget:
                        size_hint_y: None
                        height: 5
                        canvas.before:
                            Color:
                                rgba: 0.906, 0.863, 0.812, 1
                            Rectangle:
                                pos: self.pos
                                size: self.size
                            Color:
                                rgba: root.tasa_cobro_color
                            Rectangle:
                                pos: self.pos
                                size: self.width * root.tasa_cobro_pct / 100.0, self.height

            # Fila 3 — variación recaudo y PQR por tipo
            GridLayout:
                cols: 2
                spacing: 14
                size_hint_y: None
                height: 110

                AccentCard:
                    accent_color: root.variacion_rec_color
                    padding: [16, 12]
                    Label:
                        text: root.variacion_recaudo
                        font_size: 22
                        bold: True
                        color: root.variacion_rec_color
                        halign: 'left'
                        text_size: self.size
                    Label:
                        text: 'Variación recaudo vs mes anterior'
                        font_size: 11
                        color: 0.549, 0.502, 0.467, 1
                        halign: 'left'
                        text_size: self.size

                AccentCard:
                    accent_color: 0.435, 0.212, 0.682, 1
                    padding: [16, 12]
                    Label:
                        text: root.pqr_por_tipo
                        font_size: 12
                        bold: True
                        color: 0.106, 0.082, 0.071, 1
                        halign: 'left'
                        text_size: self.size
                    Label:
                        text: 'PQR por tipo'
                        font_size: 11
                        color: 0.549, 0.502, 0.467, 1
                        halign: 'left'
                        text_size: self.size

            Widget

# ============================================================
#  IMPORTAR
# ============================================================
<ImportarScreen>:
    canvas.before:
        Color:
            rgba: 0.945, 0.918, 0.882, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'horizontal'

        MenuLateral:
            pantalla_actual: 'importar'
            rol: app.user_rol

        BoxLayout:
            orientation: 'vertical'
            padding: [40, 32]
            spacing: 18

            Label:
                text: 'Importar Archivos Excel'
                font_name: 'Sora'
                font_size: 22
                bold: True
                color: 0.106, 0.082, 0.071, 1
                size_hint_y: None
                height: 36
                halign: 'left'
                text_size: self.size

            Label:
                text: 'Selecciona el tipo de archivo Excel a importar'
                font_size: 13
                color: 0.549, 0.502, 0.467, 1
                size_hint_y: None
                height: 24
                halign: 'left'
                text_size: self.size

            Widget:
                size_hint_y: None
                height: 8

            GridLayout:
                cols: 1
                spacing: 12
                size_hint: 0.55, None
                height: 196
                pos_hint: {'center_x': 0.5}

                PillButton:
                    text: 'Importar Catastro  (suscriptores)'
                    font_size: 14
                    size_hint_y: None
                    height: 56
                    bg_color: 0.106, 0.082, 0.071, 1
                    pressed_color: 0.082, 0.063, 0.055, 1
                    pill_radius: 10
                    on_press: root.seleccionar_archivo('catastro')

                PillButton:
                    text: 'Importar Facturación'
                    font_size: 14
                    size_hint_y: None
                    height: 56
                    pill_radius: 10
                    on_press: root.seleccionar_archivo('facturacion')

                PillButton:
                    text: 'Importar Recaudo'
                    font_size: 14
                    size_hint_y: None
                    height: 56
                    bg_color: 0.753, 0.227, 0.129, 1
                    pressed_color: 0.600, 0.180, 0.100, 1
                    pill_radius: 10
                    on_press: root.seleccionar_archivo('recaudo')

            Label:
                text: root.mensaje
                font_size: 13
                color: root.color_msg
                size_hint_y: None
                height: 36
                halign: 'center'
                text_size: self.size

            Widget

# ============================================================
#  SUSCRIPTORES
# ============================================================
<SuscriptoresScreen>:
    canvas.before:
        Color:
            rgba: 0.945, 0.918, 0.882, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'horizontal'

        MenuLateral:
            pantalla_actual: 'suscriptores'
            rol: app.user_rol

        BoxLayout:
            orientation: 'vertical'
            padding: [24, 20]
            spacing: 12

            Label:
                text: 'Suscriptores'
                font_name: 'Sora'
                font_size: 22
                bold: True
                color: 0.106, 0.082, 0.071, 1
                size_hint_y: None
                height: 36
                halign: 'left'
                text_size: self.size

            # Barra de búsqueda
            BoxLayout:
                size_hint_y: None
                height: 42
                spacing: 10

                # ── Pill de búsqueda ──
                FilterPill:
                    size_hint_x: 0.52
                    spacing: 0
                    padding: [14, 0, 8, 0]

                    Label:
                        text: '⌕'
                        font_size: 17
                        color: 0.549, 0.502, 0.467, 1
                        size_hint_x: None
                        width: 24

                    TextInput:
                        id: inp_buscar
                        hint_text: 'Buscar por cuenta o nombre…'
                        multiline: False
                        background_color: 0, 0, 0, 0
                        background_normal: ''
                        background_active: ''
                        foreground_color: 0.106, 0.082, 0.071, 1
                        cursor_color: 0.914, 0.306, 0.173, 1
                        hint_text_color: 0.753, 0.710, 0.675, 1
                        padding: [6, 11, 4, 0]
                        font_size: 12
                        on_text_validate: root.buscar(self.text)

                # ── Buscar ──
                PillButton:
                    text: 'Buscar'
                    size_hint_x: 0.13
                    font_size: 12
                    on_press: root.buscar(inp_buscar.text)

                # ── Mostrar todos ──
                PillButton:
                    text: 'Ver todos'
                    size_hint_x: 0.15
                    font_size: 12
                    bg_color: 1, 1, 1, 1
                    pressed_color: 0.945, 0.918, 0.882, 1
                    fg_color: 0.106, 0.082, 0.071, 1
                    border_color: 0.906, 0.863, 0.812, 1
                    on_press: root.mostrar_todos()

                # ── + Nuevo ──
                PillButton:
                    text: '+ Nuevo'
                    size_hint_x: 0.15
                    font_size: 12
                    bg_color: 0.122, 0.533, 0.220, 1
                    pressed_color: 0.090, 0.430, 0.170, 1
                    on_press: root.nuevo_suscriptor()

                # ── Exportar Excel ──
                PillButton:
                    text: '↓ Excel'
                    size_hint_x: 0.15
                    font_size: 12
                    bg_color: 0.106, 0.082, 0.071, 1
                    pressed_color: 0.082, 0.063, 0.055, 1
                    on_press: root.exportar_excel()

            Label:
                text: root.mensaje
                color: 0.549, 0.502, 0.467, 1
                size_hint_y: None
                height: 20
                font_size: 12
                halign: 'left'
                text_size: self.size

            # Encabezado tabla
            TableHeader:
                Label:
                    text: 'Cuenta'
                    bold: True
                    color: 0.906, 0.863, 0.812, 1
                    size_hint_x: 0.18
                    font_size: 12
                    halign: 'left'
                    valign: 'middle'
                    on_size: self.text_size = (self.width - 8, self.height)
                Label:
                    text: 'Nombre'
                    bold: True
                    color: 0.906, 0.863, 0.812, 1
                    size_hint_x: 0.36
                    font_size: 12
                    halign: 'left'
                    valign: 'middle'
                    on_size: self.text_size = (self.width - 8, self.height)
                Label:
                    text: 'Barrio'
                    bold: True
                    color: 0.906, 0.863, 0.812, 1
                    size_hint_x: 0.18
                    font_size: 12
                    halign: 'left'
                    valign: 'middle'
                    on_size: self.text_size = (self.width - 8, self.height)
                Label:
                    text: 'Estrato'
                    bold: True
                    color: 0.906, 0.863, 0.812, 1
                    size_hint_x: 0.09
                    font_size: 12
                    halign: 'center'
                    valign: 'middle'
                    on_size: self.text_size = self.size
                Label:
                    text: 'Estado'
                    bold: True
                    color: 0.906, 0.863, 0.812, 1
                    size_hint_x: 0.12
                    font_size: 12
                    halign: 'left'
                    valign: 'middle'
                    on_size: self.text_size = (self.width - 4, self.height)
                Label:
                    text: 'Ver'
                    bold: True
                    color: 0.906, 0.863, 0.812, 1
                    size_hint_x: 0.07
                    font_size: 12
                    halign: 'center'
                    valign: 'middle'
                    on_size: self.text_size = self.size

            ScrollView:
                BoxLayout:
                    id: lista_suscriptores
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: 1

# ============================================================
#  FACTURACIÓN
# ============================================================
<FacturacionScreen>:
    canvas.before:
        Color:
            rgba: 0.945, 0.918, 0.882, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'horizontal'

        MenuLateral:
            pantalla_actual: 'facturacion'
            rol: app.user_rol

        BoxLayout:
            orientation: 'vertical'
            padding: [24, 20]
            spacing: 12

            Label:
                text: 'Facturación por Período'
                font_name: 'Sora'
                font_size: 22
                bold: True
                color: 0.106, 0.082, 0.071, 1
                size_hint_y: None
                height: 36
                halign: 'left'
                text_size: self.size

            # Filtros
            BoxLayout:
                size_hint_y: None
                height: 42
                spacing: 10

                # ── Spinner Año ──
                FilterPill:
                    size_hint_x: 0.13
                    Spinner:
                        id: spinner_año
                        text: 'Año'
                        values: []
                        background_color: 0, 0, 0, 0
                        background_normal: ''
                        color: 0.106, 0.082, 0.071, 1
                        font_size: 13

                # ── Spinner Mes ──
                FilterPill:
                    size_hint_x: 0.12
                    Spinner:
                        id: spinner_mes
                        text: 'Mes'
                        values: []
                        background_color: 0, 0, 0, 0
                        background_normal: ''
                        color: 0.106, 0.082, 0.071, 1
                        font_size: 13

                # ── Consultar ──
                PillButton:
                    text: 'Consultar'
                    size_hint_x: 0.15
                    font_size: 13
                    on_press: root.consultar()

                Label:
                    text: root.mensaje
                    color: 0.549, 0.502, 0.467, 1
                    font_size: 12
                    halign: 'left'
                    text_size: self.size

            # Tarjetas resumen
            GridLayout:
                cols: 4
                size_hint_y: None
                height: 92
                spacing: 14

                AccentCard:
                    accent_color: 0.122, 0.533, 0.220, 1
                    padding: [16, 10]
                    Label:
                        text: root.total_facturado
                        font_size: 20
                        bold: True
                        color: 0.106, 0.082, 0.071, 1
                        halign: 'left'
                        text_size: self.size
                    Label:
                        text: 'Facturado'
                        font_size: 12
                        color: 0.549, 0.502, 0.467, 1
                        halign: 'left'
                        text_size: self.size

                AccentCard:
                    accent_color: 0.200, 0.470, 0.820, 1
                    padding: [16, 10]
                    Label:
                        text: root.total_recaudado
                        font_size: 20
                        bold: True
                        color: 0.106, 0.082, 0.071, 1
                        halign: 'left'
                        text_size: self.size
                    Label:
                        text: 'Recaudado'
                        font_size: 12
                        color: 0.549, 0.502, 0.467, 1
                        halign: 'left'
                        text_size: self.size

                AccentCard:
                    accent_color: 0.914, 0.306, 0.173, 1
                    padding: [16, 10]
                    Label:
                        text: root.deuda_periodo
                        font_size: 20
                        bold: True
                        color: 0.914, 0.306, 0.173, 1
                        halign: 'left'
                        text_size: self.size
                    Label:
                        text: 'Deuda del período'
                        font_size: 12
                        color: 0.549, 0.502, 0.467, 1
                        halign: 'left'
                        text_size: self.size

                AccentCard:
                    accent_color: 0.533, 0.200, 0.820, 1
                    padding: [16, 10]
                    Label:
                        text: root.recaudo_mes_cal
                        font_size: 20
                        bold: True
                        color: 0.106, 0.082, 0.071, 1
                        halign: 'left'
                        text_size: self.size
                    Label:
                        text: 'Cobrado este mes'
                        font_size: 12
                        color: 0.549, 0.502, 0.467, 1
                        halign: 'left'
                        text_size: self.size

            # Tablas
            BoxLayout:
                orientation: 'horizontal'
                spacing: 16

                # Estrato
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_x: 0.28

                    Label:
                        text: 'Por estrato'
                        bold: True
                        color: 0.106, 0.082, 0.071, 1
                        size_hint_y: None
                        height: 26
                        halign: 'left'
                        text_size: self.size
                        font_size: 13

                    BoxLayout:
                        size_hint_y: None
                        height: 28
                        canvas.before:
                            Color:
                                rgba: 0.106, 0.082, 0.071, 1
                            Rectangle:
                                pos: self.pos
                                size: self.size
                        Label:
                            text: 'Estrato'
                            bold: True
                            color: 0.906, 0.863, 0.812, 1
                            font_size: 12
                        Label:
                            text: 'Facturas'
                            bold: True
                            color: 0.906, 0.863, 0.812, 1
                            font_size: 12
                        Label:
                            text: 'Total'
                            bold: True
                            color: 0.906, 0.863, 0.812, 1
                            font_size: 12

                    ScrollView:
                        GridLayout:
                            id: tabla_estratos
                            cols: 3
                            size_hint_y: None
                            row_default_height: 28
                            row_force_default: True
                            height: self.minimum_height

                # Pendientes / Pagadas / Recaudos del mes
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_x: 0.72

                    # ── Tabs + controles ──
                    BoxLayout:
                        size_hint_y: None
                        height: 38
                        spacing: 6

                        TabButton:
                            id: tab_pendientes
                            text: 'Pendientes'
                            size_hint_x: None
                            width: 100
                            font_size: 12
                            is_active: True
                            on_press: root.cambiar_vista('pendientes')

                        TabButton:
                            id: tab_pagadas
                            text: 'Pagadas'
                            size_hint_x: None
                            width: 84
                            font_size: 12
                            on_press: root.cambiar_vista('pagadas')

                        TabButton:
                            id: tab_recaudos
                            text: 'Recaudos del mes'
                            size_hint_x: None
                            width: 148
                            font_size: 12
                            on_press: root.cambiar_vista('recaudos_mes')

                        TabButton:
                            id: tab_estrato
                            text: 'Por Estrato'
                            size_hint_x: None
                            width: 90
                            font_size: 12
                            on_press: root.cambiar_vista('por_estrato')

                        TabButton:
                            id: tab_barrio
                            text: 'Por Barrio'
                            size_hint_x: None
                            width: 82
                            font_size: 12
                            on_press: root.cambiar_vista('por_barrio')

                        Widget:

                        FilterPill:
                            size_hint_x: 0.42
                            pill_radius: 16
                            TextInput:
                                id: buscador
                                hint_text: '⌕  nombre o cuenta…'
                                background_color: 0, 0, 0, 0
                                foreground_color: 0.106, 0.082, 0.071, 1
                                multiline: False
                                font_size: 14
                                padding: [14, 10]
                                on_text: root.buscar(self.text)

                        FilterPill:
                            id: box_barrio
                            size_hint_x: None
                            width: 148
                            pill_radius: 16
                            Spinner:
                                id: spinner_barrio
                                text: 'Todos'
                                values: root.barrios_disponibles
                                background_color: 0, 0, 0, 0
                                background_normal: ''
                                color: 0.106, 0.082, 0.071, 1
                                font_size: 12
                                on_text: root.filtrar_barrio(self.text)

                    # ── Cabecera dinámica ──
                    BoxLayout:
                        id: cabecera_lista
                        size_hint_y: None
                        height: 28
                        spacing: 2
                        canvas.before:
                            Color:
                                rgba: 0.106, 0.082, 0.071, 1
                            Rectangle:
                                pos: self.pos
                                size: self.size

                    ScrollView:
                        BoxLayout:
                            id: lista_principal
                            orientation: 'vertical'
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: 1

                    # ── Paginación + exportar ──
                    BoxLayout:
                        size_hint_y: None
                        height: 36
                        spacing: 8
                        padding: [4, 3]
                        canvas.before:
                            Color:
                                rgba: 0.988, 0.969, 0.945, 1
                            Rectangle:
                                pos: self.pos
                                size: self.size
                        PillButton:
                            text: '← Anterior'
                            size_hint_x: None
                            width: 96
                            font_size: 11
                            bg_color: 0.906, 0.863, 0.812, 1
                            pressed_color: 0.860, 0.820, 0.770, 1
                            fg_color: 0.106, 0.082, 0.071, 1
                            pill_radius: 8
                            on_press: root.pagina_anterior()
                        Label:
                            text: root.info_lista
                            font_size: 11
                            color: 0.549, 0.502, 0.467, 1
                        PillButton:
                            text: 'Siguiente →'
                            size_hint_x: None
                            width: 96
                            font_size: 11
                            pill_radius: 8
                            on_press: root.pagina_siguiente()
                        PillButton:
                            text: 'Exportar CSV'
                            size_hint_x: None
                            width: 110
                            font_size: 11
                            bg_color: 0.106, 0.082, 0.071, 1
                            pressed_color: 0.082, 0.063, 0.055, 1
                            pill_radius: 8
                            on_press: root.exportar_csv()

# ============================================================
#  TICKETS / PQR
# ============================================================
<TicketsScreen>:
    canvas.before:
        Color:
            rgba: 0.945, 0.918, 0.882, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'horizontal'

        MenuLateral:
            pantalla_actual: 'tickets'
            rol: app.user_rol

        BoxLayout:
            orientation: 'vertical'
            padding: [24, 20]
            spacing: 12

            Label:
                text: 'PQR — Peticiones, Quejas y Reclamos'
                font_name: 'Sora'
                font_size: 22
                bold: True
                color: 0.106, 0.082, 0.071, 1
                size_hint_y: None
                height: 36
                halign: 'left'
                text_size: self.size

            BoxLayout:
                size_hint_y: None
                height: 42
                spacing: 10

                # ── + Nueva PQR ──
                PillButton:
                    text: '+ Nueva PQR'
                    size_hint_x: 0.18
                    font_size: 12
                    bg_color: 0.122, 0.533, 0.220, 1
                    pressed_color: 0.090, 0.430, 0.170, 1
                    on_press: root.nueva_pqr()

                # ── Filtro Estado ──
                FilterPill:
                    size_hint_x: 0.22
                    Label:
                        text: 'Estado'
                        size_hint_x: None
                        width: 46
                        font_size: 10
                        bold: True
                        color: 0.549, 0.502, 0.467, 1
                    Spinner:
                        id: filtro_estado
                        text: 'Todos'
                        values: ['Todos', 'Abierto', 'En Proceso', 'Resuelto']
                        background_color: 0, 0, 0, 0
                        background_normal: ''
                        color: 0.106, 0.082, 0.071, 1
                        font_size: 12
                        on_text: root.cargar_lista()

                # ── Filtro Tipo ──
                FilterPill:
                    size_hint_x: 0.22
                    Label:
                        text: 'Tipo'
                        size_hint_x: None
                        width: 36
                        font_size: 10
                        bold: True
                        color: 0.549, 0.502, 0.467, 1
                    Spinner:
                        id: filtro_tipo
                        text: 'Todos'
                        values: ['Todos', 'Petición', 'Queja', 'Recurso', 'Reclamo']
                        background_color: 0, 0, 0, 0
                        background_normal: ''
                        color: 0.106, 0.082, 0.071, 1
                        font_size: 12
                        on_text: root.cargar_lista()

                Label:
                    text: root.mensaje
                    color: 0.549, 0.502, 0.467, 1
                    font_size: 11
                    halign: 'left'
                    text_size: self.size

            # Encabezado tabla
            BoxLayout:
                size_hint_y: None
                height: 38
                spacing: 2
                canvas.before:
                    Color:
                        rgba: 0.106, 0.082, 0.071, 1
                    Rectangle:
                        pos: self.pos
                        size: self.size

                Label:
                    text: '#'
                    bold: True
                    color: 0.906, 0.863, 0.812, 1
                    size_hint_x: 0.06
                    font_size: 12
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.width - 4, self.height
                Label:
                    text: 'Suscriptor'
                    bold: True
                    color: 0.906, 0.863, 0.812, 1
                    size_hint_x: 0.22
                    font_size: 12
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.width - 4, self.height
                Label:
                    text: 'Tipo'
                    bold: True
                    color: 0.906, 0.863, 0.812, 1
                    size_hint_x: 0.13
                    font_size: 12
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.width - 4, self.height
                Label:
                    text: 'Asunto'
                    bold: True
                    color: 0.906, 0.863, 0.812, 1
                    size_hint_x: 0.27
                    font_size: 12
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.width - 4, self.height
                Label:
                    text: 'Estado'
                    bold: True
                    color: 0.906, 0.863, 0.812, 1
                    size_hint_x: 0.14
                    font_size: 12
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.width - 4, self.height
                Label:
                    text: 'Fecha'
                    bold: True
                    color: 0.906, 0.863, 0.812, 1
                    size_hint_x: 0.11
                    font_size: 12
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.width - 4, self.height
                Label:
                    text: 'Ver'
                    bold: True
                    color: 0.906, 0.863, 0.812, 1
                    size_hint_x: 0.07
                    font_size: 12
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size

            ScrollView:
                BoxLayout:
                    id: lista_pqr
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: 1

